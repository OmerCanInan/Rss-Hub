{
  "name": "gundemim",
  "private": true,
  "version": "1.1.7",
  "description": "Gündemim - Yeni Nesil Kişiselleştirilmiş RSS ve Haber Okuyucu",
  "author": "OmerCanInan",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev-react": "vite --host",
    "dev-electron": "cross-env IS_DEV=true wait-on http://localhost:5173 && electron .",
    "dev": "concurrently \"npm run dev-react\" \"npm run dev-electron\"",
    "build": "vite build",
    "lint": "eslint .",
    "pack-win": "npm run build && electron-builder --win",
    "pack-mac": "npm run build && electron-builder --mac",
    "pack-linux": "npm run build && electron-builder --linux",
    "android-sync": "vite build && cap sync android",
    "ios-sync": "cap sync ios",
    "postinstall": "node scripts/fix-gradle.cjs"
  },
  "build": {
    "appId": "com.omercan.gundemim",
    "productName": "Gundemim",
    "directories": {
      "output": "pack"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gundemim",
      "artifactName": "${productName}-Setup.${ext}"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.js"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "OmerCanInan",
        "repo": "Gundemim"
      }
    ]
  },
  "dependencies": {
    "@capacitor-community/text-to-speech": "^6.0.0",
    "@capacitor-mlkit/translation": "^7.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@electron/packager": "^18.3.3",
    "@eslint/js": "^8.57.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.9.0",
    "jsdom": "^25.0.1",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
